GRAFANA_URL=https://grafana.example.com
GRAFANA_API_TOKEN=replace_me
GRAFANA_DASHBOARD_UID=replace_me

# AI
AI_PROVIDER=ollama  # ollama | openai | none

# Ollama (local Llama3)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_S=300\nOLLAMA_NUM_PREDICT=900\n
# OpenAI (optional)
OPENAI_API_KEY=replace_me
OPENAI_MODEL=replace_me

# Time series query + anomaly detection
ENABLE_TIMESERIES_QUERY=false
TIMESERIES_MAX_PANELS=0
ANOMALY_Z_THRESHOLD=6.0

# Service auth (optional; if set, send X-API-Key header)
SERVICE_API_KEY=replace_me

# Embed auth for Grafana Text panel iframe (optional; token query parameter)
SERVICE_EMBED_TOKEN=replace_me



# CORS for Grafana panel plugin (example: http://192.168.1.109:3000)
CORS_ALLOW_ORIGINS=

